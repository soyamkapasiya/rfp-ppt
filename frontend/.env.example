# ── Frontend environment variables ───────────────────────────────────
# Copy this file to .env.local and adjust values.
# Vite only exposes variables prefixed with VITE_ to the browser bundle.

# Base URL of the RFP AI API backend (no trailing slash)
VITE_API_BASE=http://localhost:8000/api/v1

# API key sent as X-API-Key header on every request
# Must match one of api_key_editor / api_key_admin in the backend .env
VITE_API_KEY=editor-local-key
